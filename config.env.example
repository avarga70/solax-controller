# ── Inverter ──────────────────────────────────────────────────────────────────
INVERTER_IP=192.168.1.xxx          # Local IP of your GoodWe inverter

# ── MySQL (PV_run table) ──────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_DB=your_database_name
MYSQL_USER=your_user
MYSQL_PASSWORD=your_password

# ── System ────────────────────────────────────────────────────────────────────
PV_SOURCE=VV_PV                    # psource filter in PV_run
BATTERY_CAPACITY_WH=7100           # Usable battery capacity in Wh (adjust for your pack)
CHARGE_RATE_W=2750                 # Max charge rate in W (20→98% in ~2h for 7.1 kWh pack)
HISTORY_MONTHS=24                  # How many months of PV_run history to use for patterns

# ── PV Generation Forecast (forecast.solar, free, no account needed) ──────────
# Fill in your panel parameters to use weather-based PV forecast.
# Leave PV_KWP=0 (or blank) to disable and fall back to historical patterns.
PV_LAT=49.8239                     # Site latitude  (decimal degrees north)
PV_LON=18.1256                     # Site longitude (decimal degrees east)
PV_DEC=30                          # Panel tilt angle in degrees (0=flat, 30=typical roof)
PV_AZ=0                            # Panel azimuth (-90=East, 0=South, 90=West)
PV_KWP=4.56                        # Installed panel peak power in kWp

# ── Scheduled fixed loads ────────────────────────────────────────────────────
# Known daily loads guaranteed in load_remaining_wh (prevents pv_fills_battery
# from being set when PV actually won't cover the load after DHW heating).
# Set DHW_WH=0 to disable.  Hours are 0-23, end is exclusive.
DHW_START_HOUR=14                  # Hour when DHW heating starts
DHW_END_HOUR=15                    # Hour when DHW heating ends (exclusive)
DHW_WH=2550                        # Wh consumed by DHW heater in that window

# ── Export blocking ───────────────────────────────────────────────────────────
# When spot prices are deeply negative the grid charges YOU for every kWh
# exported.  Setting EXPORT_BLOCK_ENABLED=1 makes the controller tell the
# inverter to curtail excess PV (set export limit to 0 W) whenever the current
# price is at or below EXPORT_BLOCK_THRESHOLD.  The block is lifted as soon as
# prices recover.
EXPORT_BLOCK_ENABLED=0             # 1 = activate export blocking
EXPORT_BLOCK_THRESHOLD=-500        # CZK/MWh — block export below this price

# ── Distribution tariff surcharge ────────────────────────────────────────────
# Regulated distribution fees vary by time-of-use (set annually by ERU).
# During DIST_PEAK_HOURS the fee is higher; the delta is added to the spot price
# before the ECO_CHARGE (Rule 2) decision, so grid charging is suppressed unless
# the spot price is low enough to compensate.
# Values below: ČEZ Distribuce 2025 (adjust for your distributor/year).
DIST_FEE_NORMAL=140.97             # CZK/MWh — normal distribution fee
DIST_FEE_PEAK=913.27               # CZK/MWh — peak distribution fee
DIST_PEAK_HOURS=8,12,15,19          # hours (0-23) when peak fee applies
# Dynamic thresholds are computed each cycle from the next ~24h of spot prices.
# The fixed values below are only used as fallback when fewer than 6 prices
# are available in EL_dailypr.
CHEAP_PERCENTILE=25                # Bottom N% of upcoming prices = cheap
EXPENSIVE_PERCENTILE=75            # Top N% of upcoming prices = expensive
PRICE_CHEAP=1500                   # CZK/MWh fallback for cheap threshold
PRICE_EXPENSIVE=3000               # CZK/MWh fallback for expensive threshold
RECHARGE_HORIZON_H=13              # Last tomorrow hour included in threshold window (caps distortion from afternoon prices)

# ── SOC limits ────────────────────────────────────────────────────────────────
MIN_SOC=20                         # % default battery discharge floor
NIGHT_MIN_SOC=30                   # % minimum SOC to keep overnight (21:00–06:00)
MIN_SOC_FLOOR=10                   # % absolute minimum — only during expensive price hours
MIN_SOC_SAVE=50                    # % raised when price is cheap (conserve battery, refill it cheaply)
CHARGE_SOC_LIMIT=95                # Maximum SOC when grid-charging

# ── Planned outage pre-charge ─────────────────────────────────────────────────
OUTAGE_PRE_CHARGE_SOC=98           # % target SOC before a planned grid outage
OUTAGE_LEAD_HOURS=4                # max hours in advance to start pre-charging

# ── HA (High Availability) ────────────────────────────────────────────────────
# Run solar_controller.py on both node1 and node2 with these settings.
# Only the lease-holder sends commands to the inverter; the other monitors.
# Requires network access to the PXC cluster from both nodes.
HA_ENABLED=0                       # Set to 1 to enable leader election
NODE_NAME=node1                    # Unique name for this node (use hostname)
LOOP_INTERVAL_MINUTES=5           # Control cycle in minutes

# ── Smart discharge ───────────────────────────────────────────────────────────
# When enabled (default), discharge_start is chosen by ranking hours on
# effective_price × expected_load (value) filtered by round-trip break-even vs
# the cheapest upcoming recharge.  The Rule-6 overnight hold floor is also
# lowered to the minimum SOC needed for the morning peak, allowing the battery
# to serve load at profitable pre-peak prices rather than sitting idle at 98%.
# Set to 0 to revert to the original conservative behaviour.
SMART_DISCHARGE=1

# ── Safety ────────────────────────────────────────────────────────────────────
TEST_MODE=1                        # Set to 0 to go live (also: python3 solar_controller.py --test)
